{
  "name": "hermes-dashboard",
  "version": "0.2.0",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "env:bootstrap": "bash scripts/bootstrap-env.sh",
    "lint": "eslint",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 src/lib/*.test.ts",
    "test:e2e": "pnpm build && playwright test",
    "prepare:standalone": "bash scripts/prepare-standalone.sh",
    "build:standalone": "pnpm build && pnpm run prepare:standalone",
    "postbuild": "pnpm run prepare:standalone"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "google-auth-library": "^10.5.0",
    "imapflow": "^1.2.9",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^9.0.7"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@playwright/test": "^1.56.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
