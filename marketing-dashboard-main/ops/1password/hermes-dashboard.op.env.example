# 1Password op run env template (non-secret)
#
# This file is intended to be used with:
#   op run --env-file=/etc/hermes-dashboard/hermes-dashboard.op.env -- <command>
#
# It contains only op:// references (no secrets in plaintext).
# Put non-secret config in /etc/hermes-dashboard/hermes-dashboard.env.

# Auth bootstrap (used only when users table is empty)
AUTH_USER=op://example-vault/hermes-dashboard/AUTH_USER
AUTH_PASS=op://example-vault/hermes-dashboard/AUTH_PASS

# API key auth
API_KEY=op://example-vault/hermes-dashboard/API_KEY

# Website analytics (Plausible)
PLAUSIBLE_SITE_ID=op://example-vault/hermes-dashboard/PLAUSIBLE_SITE_ID
PLAUSIBLE_API_KEY=op://example-vault/hermes-dashboard/PLAUSIBLE_API_KEY
# Optional (defaults to https://plausible.io)
# PLAUSIBLE_BASE_URL=op://example-vault/hermes-dashboard/PLAUSIBLE_BASE_URL

# Optional embeds (must be http/https URLs)
# HERMES_ANALYTICS_WEBSITE_IFRAME_URL=op://example-vault/hermes-dashboard/HERMES_ANALYTICS_WEBSITE_IFRAME_URL
# HERMES_ANALYTICS_SOCIAL_IFRAME_URL=op://example-vault/hermes-dashboard/HERMES_ANALYTICS_SOCIAL_IFRAME_URL


# Google Analytics tag (measurement id; not a secret)
NEXT_PUBLIC_GA_ID=op://example-vault/hermes-dashboard/NEXT_PUBLIC_GA_ID
# Alternatively:
# GA_MEASUREMENT_ID=op://example-vault/hermes-dashboard/GA_MEASUREMENT_ID

# Mailchimp
MAILCHIMP_API_KEY=op://example-vault/hermes-dashboard/MAILCHIMP_API_KEY


# Website analytics (Google Analytics 4 Data API)
GA4_PROPERTY_ID=op://example-vault/hermes-dashboard/GA4_PROPERTY_ID
# Store the full service-account JSON as a secure text field.
GA4_SERVICE_ACCOUNT_JSON=op://example-vault/hermes-dashboard/GA4_SERVICE_ACCOUNT_JSON
# Alternatively (base64):
# GA4_SERVICE_ACCOUNT_JSON_B64=op://example-vault/hermes-dashboard/GA4_SERVICE_ACCOUNT_JSON_B64


# Social native connectors
X_BEARER_TOKEN=op://example-vault/hermes-dashboard/X_BEARER_TOKEN
X_USERNAME=op://example-vault/hermes-dashboard/X_USERNAME

# LinkedIn (optional; org analytics)
# LINKEDIN_ACCESS_TOKEN=op://example-vault/hermes-dashboard/LINKEDIN_ACCESS_TOKEN
# LINKEDIN_ORGANIZATION_URN=op://example-vault/hermes-dashboard/LINKEDIN_ORGANIZATION_URN
# Optional API version header (yyyyMM)
# LINKEDIN_VERSION=op://example-vault/hermes-dashboard/LINKEDIN_VERSION
